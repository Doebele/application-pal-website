                <!-- Columns header row -->
                <rect x="216" y="12" width="130" height="24" rx="4" fill="#21262d"/>
                <text x="281" y="28" fill="#8b949e" font-size="11" text-anchor="middle" font-family="monospace">Wishlist</text>
                <rect x="356" y="12" width="130" height="24" rx="4" fill="#21262d"/>
                <text x="421" y="28" fill="#8b949e" font-size="11" text-anchor="middle" font-family="monospace">Applied</text>
                <rect x="496" y="12" width="130" height="24" rx="4" fill="#21262d"/>
                <text x="561" y="28" fill="#3fb950" font-size="11" text-anchor="middle" font-family="monospace">Interview</text>
