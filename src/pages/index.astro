                <!-- Day headers -->
                {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map((d, i) => (
                  `<text x="${32 + i * 124}" y="72" fill="#8b949e" font-size="11" font-family="monospace">${d}</text>`
                ))}
                <!-- Grid lines -->
                <line x1="0" y1="80" x2="900" y2="80" stroke="#21262d" stroke-width="1"/>
                <!-- Week rows -->
                <rect x="32" y="88" width="110" height="80" rx="4" fill="#21262d" opacity=".4"/>
