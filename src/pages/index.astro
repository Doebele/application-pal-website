---
import Layout from '../layouts/Layout.astro';

const GITHUB_URL = 'https://github.com/Doebele/application-pal';
const INSTALL_URL = '/application-pal-website/install';

const features = [
  {
    icon: '🤖',
    grad: 'linear-gradient(135deg,#0a3e42,#dc143c)',
    title: 'AI Coaching',
    desc: 'Stage-specific guidance — not generic tips. Checks ATS keyword gaps, generates interview prep guides and salary negotiation scripts, then hands you an onboarding checklist after you accept.',
  },
  {
    icon: '📋',
    grad: 'linear-gradient(135deg,#0a3e42,#006b73)',
    title: 'Kanban + Table View',
    desc: 'Drag applications from Applied → Phone Screen → Interview → Offer. Switch to table view for a spreadsheet-style overview with 15 configurable columns including AI match score and salary data.',
  },
  {
    icon: '📅',
    grad: 'linear-gradient(135deg,#1a7045,#0a3e42)',
    title: 'Calendar',
    desc: 'Monthly and weekly calendar views show every interview, deadline, and follow-up. Log format, location, and interviewer details. Export to your calendar app when done.',
  },
  {
    icon: '📁',
    grad: 'linear-gradient(135deg,#f59e0b,#ef4444)',
    title: 'Google Drive',
    desc: 'Connect your Google account and application-pal creates a folder for each job the moment you add it. CV templates and cover letter drafts copy over with formatting intact.',
  },
  {
    icon: '👥',
    grad: 'linear-gradient(135deg,#dc143c,#8b1a2b)',
    title: 'Multi-user',
    desc: 'One instance, multiple users. Invite-based registration keeps your server private. Every user gets an isolated workspace — no one sees anyone else\'s applications.',
  },
  {
    icon: '🏠',
    grad: 'linear-gradient(135deg,#8b1a2b,#0a3e42)',
    title: 'Flexible AI',
    desc: 'Six AI providers supported: Ollama and LM Studio run fully offline on your hardware. Anthropic, OpenAI, Google Gemini, and OpenRouter connect via your own API key.',
  },
];

const stats = [
  { num: '1', label: 'command to install' },
  { num: '6', label: 'AI providers' },
  { num: '100%', label: 'self-hosted & private' },
  { num: 'MIT', label: 'open source license' },
];

const steps = [
  {
    num: '01',
    title: 'Run one command',
    desc: 'docker compose up — the full stack starts in under a minute.',
    code: 'docker compose up -d',
  },
  {
    num: '02',
    title: 'Create your account',
    desc: 'Open localhost:8070, register, and you\'re in. No email verification, no credit card.',
    code: 'open http://localhost:8070',
  },
  {
    num: '03',
    title: 'Start tracking',
    desc: 'Add your first application, move it through the board, and let AI coaching do the rest.',
    code: null,
  },
];
---

<Layout>
  <!-- NAV -->
  <header class="nav">
    <div class="container nav-inner">
      <a href="/application-pal-website/" class="nav-logo">
        <span class="logo-mark">📎</span>
        <span>application-pal</span>
      </a>
      <nav class="nav-links">
        <a href="#features">Features</a>
        <a href="#screenshots">Preview</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="nav-gh">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          GitHub
        </a>
        <a href={INSTALL_URL} class="btn-nav-cta">Get started</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow glow-1" aria-hidden="true"></div>
    <div class="hero-glow glow-2" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-badge" data-reveal>
        <span class="badge-dot"></span>
        Open source · Local-first · Free forever
      </div>

      <h1 class="hero-title" data-reveal>
        Stop losing track.<br />
        <span class="grad-text">Start landing jobs.</span>
      </h1>

      <p class="hero-sub" data-reveal>
        application-pal runs at <code>localhost:8070</code> — no cloud account,
        no subscription, no data leaving your computer.
        One <code>docker&nbsp;compose&nbsp;up</code> and you're tracking.
      </p>

      <div class="hero-ctas" data-reveal>
        <a href={INSTALL_URL} class="btn-primary">
          Get started — it's free
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="btn-ghost">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          View on GitHub
        </a>
      </div>

      <div class="hero-stars" data-reveal>
        <a href={`${GITHUB_URL}/stargazers`} target="_blank" rel="noopener">
          <img src="https://img.shields.io/github/stars/Doebele/application-pal?style=flat&logo=github&labelColor=fff4e4&color=0a3e42" alt="GitHub stars" width="120" height="20" loading="lazy" />
        </a>
      </div>

      <!-- Floating terminal card -->
      <div class="terminal-float" aria-hidden="true" data-reveal>
        <div class="term-header">
          <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
          <span class="term-title">Terminal</span>
        </div>
        <div class="term-body">
          <div class="term-line"><span class="term-prompt">$</span> <span class="term-cmd">git clone https://github.com/Doebele/application-pal</span></div>
          <div class="term-line dim"><span class="term-prompt">$</span> <span class="term-cmd">cd application-pal</span></div>
          <div class="term-line"><span class="term-prompt">$</span> <span class="term-cmd typing">docker compose up -d</span></div>
          <div class="term-line term-out">✔ Container application-pal-db-1 <span class="ok">Started</span></div>
          <div class="term-line term-out">✔ Container application-pal-app-1 <span class="ok">Started</span></div>
          <div class="term-line term-out dim">→ Open http://localhost:8070</div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="container stats-inner">
      {stats.map(s => (
        <div class="stat" data-reveal>
          <span class="stat-num">{s.num}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section features" id="features">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 class="section-title">Everything you need. Nothing you don't.</h2>
        <p class="section-sub">Built for job seekers who want full control — and their data on their machine.</p>
      </div>
      <div class="features-grid">
        {features.map(f => (
          <div class="feature-card" data-reveal>
            <div class="feature-icon-wrap" style={`background: ${f.grad}`}>
              <span class="feature-icon">{f.icon}</span>
            </div>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section screenshots" id="screenshots">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 class="section-title">See it in action.</h2>
        <p class="section-sub">Every view runs locally. Your data never leaves your machine.</p>
      </div>

      <div class="tabs" data-reveal>
        <input type="radio" name="tab" id="tab-kanban" checked />
        <input type="radio" name="tab" id="tab-calendar" />
        <input type="radio" name="tab" id="tab-ai" />
        <input type="radio" name="tab" id="tab-drive" />

        <div class="tab-labels">
          <label for="tab-kanban">📋 Kanban Board</label>
          <label for="tab-calendar">📅 Calendar</label>
          <label for="tab-ai">🤖 AI Coaching</label>
          <label for="tab-drive">📁 Google Drive</label>
        </div>

        <div class="browser-frame">
          <div class="browser-chrome">
            <span class="bdot r"></span><span class="bdot y"></span><span class="bdot g"></span>
            <span class="address-bar">localhost:8070</span>
          </div>
          <div class="tab-panel" id="panel-kanban">
            <img src="/application-pal-website/screenshots/kanban.png" alt="Kanban board" class="screenshot-img" width="1200" height="700" loading="lazy" onerror="this.style.display='none';document.getElementById('ph-kanban').style.display='flex'" />
            <div id="ph-kanban" class="screenshot-ph">
              <svg viewBox="0 0 900 500" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="900" height="500" fill="#fef8ee"/>
                <rect x="0" y="0" width="180" height="500" fill="#ffffff"/>
                <rect x="16" y="16" width="148" height="30" rx="6" fill="#f0ece4"/>
                <rect x="16" y="58" width="148" height="26" rx="5" fill="#0a3e42" opacity=".1"/>
                <rect x="36" y="65" width="70" height="12" rx="3" fill="#0a3e42"/>
                <rect x="16" y="92" width="148" height="26" rx="5" fill="#ffffff"/>
                <rect x="36" y="99" width="55" height="12" rx="3" fill="#6b7f80"/>
                <rect x="16" y="126" width="148" height="26" rx="5" fill="#ffffff"/>
                <rect x="36" y="133" width="65" height="12" rx="3" fill="#6b7f80"/>
                <!-- columns -->
                {['Wishlist','Applied','Interview','Offer'].map((col, i) => (
                  `<g key="${col}">
                    <rect x="${196 + i*176}" y="12" width="160" height="22" rx="4" fill="#ffffff"/>
                    <text x="${276 + i*176}" y="27" fill="#6b7f80" font-size="11" text-anchor="middle" font-family="monospace">${col}</text>
                    <rect x="${196 + i*176}" y="42" width="160" height="68" rx="6" fill="#ffffff"/>
                    <rect x="${208 + i*176}" y="52" width="100" height="10" rx="2" fill="#212121" opacity=".7"/>
                    <rect x="${208 + i*176}" y="68" width="70" height="8" rx="2" fill="#6b7f80"/>
                    <rect x="${208 + i*176}" y="82" width="50" height="16" rx="8" fill="#0a3e42" opacity=".15"/>
                    <rect x="${196 + i*176}" y="118" width="160" height="58" rx="6" fill="#ffffff"/>
                    <rect x="${208 + i*176}" y="128" width="85" height="10" rx="2" fill="#212121" opacity=".5"/>
                    <rect x="${208 + i*176}" y="144" width="60" height="8" rx="2" fill="#6b7f80"/>
                  </g>`
                ))}
                <!-- Interview highlight -->
                <rect x="548" y="42" width="160" height="68" rx="6" fill="#ffffff" stroke="#1a7045" stroke-width="1.5"/>
                <rect x="560" y="52" width="100" height="10" rx="2" fill="#212121" opacity=".9"/>
                <rect x="560" y="68" width="70" height="8" rx="2" fill="#1a7045" opacity=".7"/>
              </svg>
              <span class="ph-label">📋 Kanban Board — add screenshots/kanban.png to show real UI</span>
            </div>
          </div>

          <div class="tab-panel" id="panel-calendar">
            <img src="/application-pal-website/screenshots/calendar.png" alt="Calendar view" class="screenshot-img" width="1200" height="700" loading="lazy" onerror="this.style.display='none';document.getElementById('ph-calendar').style.display='flex'" />
            <div id="ph-calendar" class="screenshot-ph">
              <svg viewBox="0 0 900 500" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="900" height="500" fill="#fef8ee"/>
                <rect x="0" y="0" width="900" height="44" fill="#fef8ee"/>
                <text x="24" y="28" fill="#212121" font-size="14" font-family="monospace" font-weight="bold">June 2026</text>
                <rect x="750" y="10" width="70" height="24" rx="5" fill="#ffffff"/>
                <text x="785" y="26" fill="#6b7f80" font-size="10" text-anchor="middle" font-family="monospace">Month</text>
                <rect x="828" y="10" width="60" height="24" rx="5" fill="#0a3e42" opacity=".2"/>
                <text x="858" y="26" fill="#0a3e42" font-size="10" text-anchor="middle" font-family="monospace">Week</text>
                <!-- Grid -->
                {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map((d, i) => (
                  `<text x="${36 + i*120}" y="66" fill="#6b7f80" font-size="10" font-family="monospace">${d}</text>`
                ))}
                <line x1="0" y1="74" x2="900" y2="74" stroke="#ffffff" stroke-width="1"/>
                <!-- Day cells -->
                {[0,1,2,3,4,5,6].map(i => (
                  `<rect x="${24 + i*120}" y="80" width="108" height="90" rx="4" fill="#fef8ee" opacity=".6"/>`
                ))}
                <!-- Events -->
                <rect x="145" y="112" width="106" height="18" rx="3" fill="#1a7045" opacity=".9"/>
                <text x="155" y="124" fill="#fef8ee" font-size="9" font-family="monospace" font-weight="bold">Interview @ Google</text>
                <rect x="385" y="96" width="106" height="18" rx="3" fill="#ef4444" opacity=".8"/>
                <text x="395" y="108" fill="#fff" font-size="9" font-family="monospace">Application deadline</text>
                <rect x="505" y="112" width="106" height="18" rx="3" fill="#0a3e42" opacity=".7"/>
                <text x="515" y="124" fill="#fff" font-size="9" font-family="monospace">Follow-up email</text>
              </svg>
              <span class="ph-label">📅 Calendar — add screenshots/calendar.png to show real UI</span>
            </div>
          </div>

          <div class="tab-panel" id="panel-ai">
            <img src="/application-pal-website/screenshots/ai-coaching.png" alt="AI Coaching" class="screenshot-img" width="1200" height="700" loading="lazy" onerror="this.style.display='none';document.getElementById('ph-ai').style.display='flex'" />
            <div id="ph-ai" class="screenshot-ph">
              <svg viewBox="0 0 900 500" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="900" height="500" fill="#fef8ee"/>
                <rect x="0" y="0" width="300" height="500" fill="#fef8ee"/>
                <rect x="16" y="16" width="268" height="76" rx="6" fill="#ffffff"/>
                <rect x="28" y="26" width="110" height="12" rx="3" fill="#212121" opacity=".8"/>
                <rect x="28" y="44" width="75" height="9" rx="2" fill="#6b7f80"/>
                <rect x="28" y="60" width="55" height="16" rx="8" fill="#1a7045" opacity=".2"/>
                <text x="55" y="71" fill="#1a7045" font-size="9" font-family="monospace">Interview</text>
                <!-- Chat -->
                <rect x="316" y="0" width="584" height="44" fill="#fef8ee"/>
                <text x="336" y="28" fill="#212121" font-size="13" font-family="monospace" font-weight="bold">🤖 AI Coach</text>
                <!-- AI bubble -->
                <rect x="328" y="56" width="380" height="88" rx="8" fill="#ffffff"/>
                <rect x="340" y="68" width="340" height="9" rx="2" fill="#6b7f80"/>
                <rect x="340" y="83" width="300" height="9" rx="2" fill="#6b7f80"/>
                <rect x="340" y="98" width="260" height="9" rx="2" fill="#6b7f80"/>
                <rect x="340" y="113" width="180" height="9" rx="2" fill="#6b7f80"/>
                <!-- Chips -->
                <rect x="328" y="156" width="118" height="24" rx="12" fill="#0a3e42" opacity=".15" stroke="#0a3e42" stroke-width="1"/>
                <text x="387" y="171" fill="#0a3e42" font-size="9" text-anchor="middle" font-family="monospace">ATS Keywords</text>
                <rect x="454" y="156" width="128" height="24" rx="12" fill="#dc143c" opacity=".15" stroke="#dc143c" stroke-width="1"/>
                <text x="518" y="171" fill="#dc143c" font-size="9" text-anchor="middle" font-family="monospace">Interview Prep</text>
                <rect x="590" y="156" width="112" height="24" rx="12" fill="#1a7045" opacity=".15" stroke="#1a7045" stroke-width="1"/>
                <text x="646" y="171" fill="#1a7045" font-size="9" text-anchor="middle" font-family="monospace">Salary Script</text>
                <!-- User bubble -->
                <rect x="520" y="196" width="352" height="52" rx="8" fill="#1a2540"/>
                <rect x="532" y="206" width="300" height="9" rx="2" fill="#0a3e42" opacity=".6"/>
                <rect x="532" y="221" width="240" height="9" rx="2" fill="#0a3e42" opacity=".4"/>
                <rect x="532" y="236" width="180" height="9" rx="2" fill="#0a3e42" opacity=".3"/>
                <!-- Input -->
                <rect x="328" y="452" width="520" height="38" rx="8" fill="#ffffff" stroke="rgba(10,62,66,0.14)" stroke-width="1"/>
                <text x="344" y="475" fill="#2a3f5f" font-size="11" font-family="monospace">Ask AI Coach anything…</text>
                <rect x="856" y="452" width="32" height="38" rx="8" fill="#0a3e42" opacity=".25"/>
              </svg>
              <span class="ph-label">🤖 AI Coaching — add screenshots/ai-coaching.png to show real UI</span>
            </div>
          </div>

          <div class="tab-panel" id="panel-drive">
            <img src="/application-pal-website/screenshots/google-drive.png" alt="Google Drive" class="screenshot-img" width="1200" height="700" loading="lazy" onerror="this.style.display='none';document.getElementById('ph-drive').style.display='flex'" />
            <div id="ph-drive" class="screenshot-ph">
              <svg viewBox="0 0 900 500" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="900" height="500" fill="#fef8ee"/>
                <rect x="0" y="0" width="900" height="44" fill="#fef8ee"/>
                <text x="24" y="27" fill="#212121" font-size="14" font-family="monospace" font-weight="bold">📁 Google Drive</text>
                <rect x="710" y="10" width="170" height="24" rx="6" fill="#1a7045" opacity=".12" stroke="#1a7045" stroke-width="1"/>
                <text x="795" y="26" fill="#1a7045" font-size="10" text-anchor="middle" font-family="monospace">✓ Connected</text>
                <!-- Folder grid 4-per-row -->
                {['Google — SWE II','Stripe — Backend','Figma — Staff Eng','Linear — Platform','Vercel — SWE','Notion — Full Stack'].map((label, i) => {
                  const col = i % 4;
                  const row = Math.floor(i / 4);
                  const x = 24 + col * 218;
                  const y = 60 + row * 145;
                  return `<g>
                    <rect x="${x}" y="${y}" width="200" height="128" rx="8" fill="#fef8ee" stroke="rgba(10,62,66,0.14)" stroke-width="1"/>
                    <text x="${x+100}" y="${y+52}" fill="#f59e0b" font-size="36" text-anchor="middle">📁</text>
                    <rect x="${x+12}" y="${y+76}" width="176" height="9" rx="2" fill="#6b7f80"/>
                    <rect x="${x+12}" y="${y+92}" width="120" height="7" rx="2" fill="rgba(10,62,66,0.14)"/>
                  </g>`;
                })}
              </svg>
              <span class="ph-label">📁 Google Drive — add screenshots/google-drive.png to show real UI</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section how" id="how-it-works">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 class="section-title">Up and running in minutes.</h2>
        <p class="section-sub">No cloud accounts, no configuration files, no surprises.</p>
      </div>
      <div class="steps-row">
        {steps.map((s, i) => (
          <div class="step-card" data-reveal>
            <div class="step-num-badge">{s.num}</div>
            {i < steps.length - 1 && <div class="step-connector" aria-hidden="true"></div>}
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.desc}</p>
            {s.code && <pre class="step-code"><code>{s.code}</code></pre>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="section social" id="social">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2 class="section-title">Trusted by job seekers everywhere.</h2>
        <p class="section-sub">See what people are saying about application-pal.</p>
      </div>
      <div class="testimonials-grid">
        <blockquote class="testimonial-card" data-reveal>
          <div class="testimonial-stars">★★★★★</div>
          <p>"I was juggling 40+ applications in a spreadsheet and losing my mind. application-pal's Kanban board kept me sane. The AI coaching caught keyword gaps in my resume I'd completely missed."</p>
          <footer>
            <div class="testimonial-avatar">SN</div>
            <div class="testimonial-meta">
              <strong>Sarah Nguyen</strong>
              <span>Software Engineer · Previously at Meta</span>
            </div>
          </footer>
        </blockquote>

        <blockquote class="testimonial-card" data-reveal>
          <div class="testimonial-stars">★★★★★</div>
          <p>"Finally, something that doesn't sell my data. The Google Drive integration is brilliant — every job gets its own folder automatically. Saved me hours of organizing documents."</p>
          <footer>
            <div class="testimonial-avatar">JC</div>
            <div class="testimonial-meta">
              <strong>James Chen</strong>
              <span>Product Manager · Previously at Stripe</span>
            </div>
          </footer>
        </blockquote>

