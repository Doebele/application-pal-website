                <text x="540" y="106" fill="#8b949e" font-size="10" font-family="monospace">6</text>
                <rect x="652" y="88" width="110" height="80" rx="4" fill="#21262d" opacity=".2"/>
                <text x="664" y="106" fill="#30363d" font-size="10" font-family="monospace">7</text>
                <rect x="776" y="88" width="110" height="80" rx="4" fill="#21262d" opacity=".2"/>
                <text x="788" y="106" fill="#30363d" font-size="10" font-family="monospace">8</text>
              </svg>
              <span class="placeholder-label">📅 Calendar View — replace with real screenshot</span>
            </div>
          </div>

          <!-- AI Coaching -->
          <div class="tab-panel" id="panel-ai">
            <img
              src="/application-pal-website/screenshots/ai-coaching.png"
              alt="AI coaching panel showing cover letter feedback and suggestions"
              class="screenshot-img"
              width="1200"
              height="700"
              loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
            <div class="screenshot-placeholder" style="display:none">
              <svg viewBox="0 0 900 520" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="900" height="520" fill="#0d1117"/>
                <!-- Left panel: application context -->
                <rect x="0" y="0" width="340" height="520" fill="#161b22"/>
                <rect x="16" y="16" width="308" height="80" rx="6" fill="#21262d"/>
