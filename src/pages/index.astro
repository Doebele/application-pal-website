<!-- Scroll reveal -->
<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
</script>

<style>
  /* ── GLOBALS ─────────────────────────────────────────────── */
  :root {
