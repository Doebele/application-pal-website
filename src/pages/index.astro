                <!-- Cards col 3 (Interview - highlighted) -->
                <rect x="496" y="46" width="130" height="70" rx="6" fill="#21262d" stroke="#3fb950" stroke-width="1"/>
                <rect x="508" y="56" width="85" height="10" rx="2" fill="#e6edf3"/>
                <rect x="508" y="72" width="48" height="8" rx="2" fill="#3fb950"/>
                <rect x="508" y="86" width="60" height="14" rx="10" fill="#3fb950" opacity=".2"/>
                <text x="538" y="97" fill="#3fb950" font-size="8" font-family="monospace">Tomorrow</text>
                <!-- Column add buttons -->
                <rect x="216" y="202" width="130" height="28" rx="6" fill="#21262d" stroke="#30363d" stroke-width="1" stroke-dasharray="4"/>
                <text x="281" y="220" fill="#30363d" font-size="18" text-anchor="middle">+</text>
              </svg>
              <span class="placeholder-label">📋 Kanban Board — replace with real screenshot</span>
            </div>
          </div>

          <!-- Calendar -->
          <div class="tab-panel" id="panel-calendar">
            <img
              src="/application-pal-website/screenshots/calendar.png"
              alt="Calendar view showing scheduled interviews and deadlines"
              class="screenshot-img"
              width="1200"
              height="700"
              loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
