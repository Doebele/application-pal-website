                <rect x="0" y="0" width="900" height="48" fill="#161b22"/>
                <text x="32" y="30" fill="#e6edf3" font-size="14" font-family="monospace" font-weight="bold">📁 Google Drive</text>
                <rect x="700" y="12" width="176" height="26" rx="6" fill="#3fb950" opacity=".15" stroke="#3fb950" stroke-width="1"/>
                <text x="788" y="29" fill="#3fb950" font-size="10" text-anchor="middle" font-family="monospace">✓ Connected</text>
                <!-- Folder grid -->
                {[
                  {x:32, label:'Google — SWE II'},
                  {x:196, label:'Stripe — Backend Eng'},
                  {x:360, label:'Figma — Staff Eng'},
                  {x:524, label:'Linear — Platform'},
                  {x:32+0, y2:240, label:'Vercel — SWE'},
                  {x:196, y2:240, label:'Notion — Backend'},
                ].map((f, i) => `
                  <rect x="${f.x}" y="${f.y2 || 72}" width="148" height="120" rx="8" fill="#21262d"/>
                  <text x="${f.x + 74}" y="${(f.y2 || 72) + 44}" fill="#f7c948" font-size="32" text-anchor="middle">📁</text>
                  <rect x="${f.x + 12}" y="${(f.y2 || 72) + 82}" width="124" height="8" rx="2" fill="#8b949e"/>
