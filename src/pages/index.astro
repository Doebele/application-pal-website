                <rect x="372" y="108" width="260" height="8" rx="2" fill="#8b949e"/>
                <rect x="372" y="124" width="180" height="8" rx="2" fill="#8b949e"/>
                <!-- Suggestion chips -->
                <rect x="360" y="166" width="120" height="24" rx="12" fill="#58a6ff" opacity=".15" stroke="#58a6ff" stroke-width="1"/>
                <text x="420" y="181" fill="#58a6ff" font-size="9" text-anchor="middle" font-family="monospace">ATS Keywords</text>
                <rect x="490" y="166" width="130" height="24" rx="12" fill="#bc8cff" opacity=".15" stroke="#bc8cff" stroke-width="1"/>
                <text x="555" y="181" fill="#bc8cff" font-size="9" text-anchor="middle" font-family="monospace">Interview Prep</text>
                <rect x="630" y="166" width="110" height="24" rx="12" fill="#3fb950" opacity=".15" stroke="#3fb950" stroke-width="1"/>
                <text x="685" y="181" fill="#3fb950" font-size="9" text-anchor="middle" font-family="monospace">Salary Script</text>
                <!-- User message -->
                <rect x="528" y="208" width="360" height="60" rx="8" fill="#1f3352"/>
                <rect x="540" y="218" width="300" height="8" rx="2" fill="#58a6ff" opacity=".6"/>
                <rect x="540" y="234" width="240" height="8" rx="2" fill="#58a6ff" opacity=".4"/>
