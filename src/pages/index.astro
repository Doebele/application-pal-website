                <rect x="40" y="95" width="80" height="14" rx="3" fill="#58a6ff"/>
                <rect x="16" y="124" width="168" height="28" rx="6" fill="#21262d"/>
                <rect x="40" y="131" width="70" height="14" rx="3" fill="#8b949e"/>
                <rect x="16" y="160" width="168" height="28" rx="6" fill="#21262d"/>
