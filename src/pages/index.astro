                <rect x="156" y="88" width="110" height="80" rx="4" fill="#21262d" opacity=".4"/>
                <text x="168" y="106" fill="#8b949e" font-size="10" font-family="monospace">3</text>
                <!-- Interview event -->
                <rect x="158" y="118" width="106" height="20" rx="3" fill="#3fb950" opacity=".85"/>
                <text x="168" y="131" fill="#0d1117" font-size="9" font-family="monospace" font-weight="bold">Interview @ Google</text>
                <rect x="280" y="88" width="110" height="80" rx="4" fill="#21262d" opacity=".4"/>
                <text x="292" y="106" fill="#8b949e" font-size="10" font-family="monospace">4</text>
                <rect x="404" y="88" width="110" height="80" rx="4" fill="#21262d" opacity=".4"/>
                <text x="416" y="106" fill="#8b949e" font-size="10" font-family="monospace">5</text>
                <!-- Deadline event -->
                <rect x="406" y="108" width="106" height="20" rx="3" fill="#f85149" opacity=".8"/>
