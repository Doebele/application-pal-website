---
import Layout from '../layouts/Layout.astro';

const GITHUB_URL = 'https://github.com/Doebele/application-pal';
const INSTALL_URL = '/application-pal-website/install';

const features = [
  {
    icon: '🤖',
    title: 'AI Coaching',
    desc: 'Stage-specific guidance — not generic tips. Checks ATS keyword gaps, generates interview prep guides and salary negotiation scripts, then hands you an onboarding checklist after you accept.',
  },
  {
    icon: '📋',
    title: 'Kanban + Table View',
    desc: 'Drag applications from Applied → Phone Screen → Interview → Offer. Switch to table view for a spreadsheet-style overview with 15 configurable columns including AI match score and salary data.',
  },
  {
    icon: '📅',
    title: 'Calendar',
    desc: 'Monthly and weekly calendar views show every interview, deadline, and follow-up. Log format (on-site, video, phone), location, and interviewer details. Export to your calendar app when done.',
  },
  {
    icon: '📁',
    title: 'Google Drive',
    desc: 'Connect your Google account and application-pal creates a folder for each job the moment you add it. CV templates and cover letter drafts copy over with formatting intact. No manual file management.',
  },
  {
    icon: '👥',
    title: 'Multi-user',
    desc: 'One instance, multiple users. Invite-based registration keeps your server private. Every user gets an isolated workspace — no one sees anyone else\'s applications.',
  },
  {
    icon: '🏠',
    title: 'Flexible AI',
    desc: 'Six AI providers supported: Ollama and LM Studio run fully offline on your hardware. Anthropic, OpenAI, Google Gemini, and OpenRouter connect via your own API key. No AI required to start.',
  },
];

const steps = [
  {
    num: '1',
    title: 'Run one command',
    desc: 'docker compose up — the full stack starts in under a minute.',
    code: 'docker compose up -d',
  },
  {
    num: '2',
    title: 'Create your account',
    desc: 'Open localhost:8070, register, and you\'re in. No email verification, no credit card.',
    code: 'open http://localhost:8070',
  },
  {
    num: '3',
    title: 'Start tracking',
    desc: 'Add your first application, move it through the board, and let AI coaching do the rest.',
    code: null,
  },
];
---

<Layout>
  <!-- NAV -->
  <header class="nav">
    <div class="container nav-inner">
      <a href="/application-pal-website/" class="nav-logo">
        <span class="logo-icon">📎</span>
        <span>application-pal</span>
      </a>
      <nav class="nav-links">
        <a href="/application-pal-website/install">Install</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="github-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
        <a href={INSTALL_URL} class="btn-nav">Get started</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="badge">Open source · Local-first · Free forever</div>
      <h1 class="hero-title">
        Stop losing track.<br />
        <span class="accent">Start landing jobs.</span>
      </h1>
      <p class="hero-sub">
        application-pal runs at <code class="inline-code">localhost:8070</code> — no cloud account,
        no subscription, no data leaving your computer.
        One <code class="inline-code">docker compose up</code> and you're tracking.
      </p>
      <div class="hero-ctas">
        <a href={INSTALL_URL} class="btn-primary">Get started with Docker</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="btn-secondary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          View on GitHub
        </a>
      </div>
      <div class="hero-stars">
        <a href={`${GITHUB_URL}/stargazers`} target="_blank" rel="noopener">
          <img
            src="https://img.shields.io/github/stars/Doebele/application-pal?style=flat&logo=github&labelColor=0d1117&color=58a6ff"
            alt="GitHub stars"
            width="120"
            height="20"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section features" id="features">
    <div class="container">
      <h2 class="section-title">Everything you need. Nothing you don't.</h2>
      <p class="section-sub">Built for job seekers who want full control over their search — and their data. All of it runs on your machine.</p>
      <div class="features-grid">
        {features.map(f => (
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">{f.icon}</span>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section screenshots" id="screenshots">
    <div class="container">
      <h2 class="section-title">See it in action.</h2>
      <p class="section-sub">Every view is local. Every file is yours.</p>

      <div class="tabs">
        <input type="radio" name="tab" id="tab-kanban" checked />
        <input type="radio" name="tab" id="tab-calendar" />
        <input type="radio" name="tab" id="tab-ai" />
        <input type="radio" name="tab" id="tab-drive" />

        <div class="tab-labels">
          <label for="tab-kanban">📋 Kanban Board</label>
          <label for="tab-calendar">📅 Calendar</label>
          <label for="tab-ai">🤖 AI Coaching</label>
          <label for="tab-drive">📁 Google Drive</label>
        </div>

        <div class="browser-frame">
          <div class="browser-chrome">
            <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
            <span class="address-bar">localhost:8070</span>
          </div>

          <!-- Kanban -->
          <div class="tab-panel" id="panel-kanban">
            <img
              src="/application-pal-website/screenshots/kanban.png"
              alt="Kanban board showing applications in columns: Wishlist, Applied, Phone Screen, Interview, Offer"
              class="screenshot-img"
              width="1200"
              height="700"
              loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
