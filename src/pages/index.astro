                <rect x="0" y="0" width="900" height="48" fill="#161b22"/>
                <text x="32" y="30" fill="#e6edf3" font-size="14" font-family="monospace" font-weight="bold">June 2026</text>
                <rect x="700" y="12" width="80" height="26" rx="6" fill="#21262d"/>
