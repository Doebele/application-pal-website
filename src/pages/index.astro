                <text x="32" y="406" fill="#e6edf3" font-size="11" font-family="monospace" font-weight="bold">Google — SWE II / Files</text>
                <rect x="32" y="416" width="200" height="28" rx="4" fill="#21262d"/>
                <text x="52" y="433" fill="#8b949e" font-size="10" font-family="monospace">📄 CV_Google_2026.pdf</text>
                <rect x="240" y="416" width="220" height="28" rx="4" fill="#21262d"/>
